{
    "name": "veinminer-addon",
    "version": "0.3.1",
    "description": "Minecraft 基岩版连锁采集行为包 - 自动环境适配",
    "type": "module",
    "scripts": {
        "build": "node build.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "pack": "node build.mjs",
        "dev": "node build.mjs --watch",
        "clean": "node -e \"require('fs').rmSync('build', {recursive: true, force: true})\" && echo 'Cleaned build/'"
    },
    "devDependencies": {
        "@minecraft/common": "^1.2.0",
        "@minecraft/server": "2.8.0",
        "@minecraft/server-ui": "2.1.0",
        "@types/node": "^22.0.0",
        "esbuild": "^0.28.1",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT",
    "overrides": {
        "@minecraft/server": "2.8.0",
        "@minecraft/server-ui": {
            "@minecraft/server": "$@minecraft/server"
        }
    }
}
