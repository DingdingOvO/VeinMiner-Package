{
    "namespace": "veinminer_ui",

    "toggle_button@common_buttons.light_text_button": {
        "$pressed_button_name": "button.menu_select",
        "button_name": "veinminer.toggle",
        "default_control_id": "veinminer_toggle_btn",
        "text": "VM",
        "font_scale_factor": 1.0,
        "color": [1.0, 1.0, 1.0],
        "shadow": true,
        "hover_text_color": [0.4, 1.0, 0.4]
    },

    "settings_button@common_buttons.light_text_button": {
        "$pressed_button_name": "button.menu_select",
        "button_name": "veinminer.settings",
        "default_control_id": "veinminer_settings_btn",
        "text": "⚙",
        "font_scale_factor": 1.2,
        "color": [1.0, 1.0, 1.0],
        "shadow": true,
        "hover_text_color": [1.0, 0.85, 0.2]
    },

    "vm_panel": {
        "type": "panel",
        "anchor_from": "bottom_right",
        "anchor_to": "bottom_right",
        "offset": [0, 72],
        "controls": [
            { "toggle_btn@veinminer_ui.toggle_button": { "size": [30, 22] } },
            { "settings_btn@veinminer_ui.settings_button": { "size": [30, 22] } }
        ]
    },

    "root_panel": {
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_front",
                "value": [
                    { "vm_panel@veinminer_ui.vm_panel": {} }
                ]
            }
        ]
    }
}