{
    "namespace": "veinminer_ui",

    "toggle_button": {
        "type": "button",
        "size": [32, 22],
        "button_click_commands": ["/scriptevent veinminer:toggle"],
        "default_control_id": "veinminer_toggle_btn",
        "text": "VM",
        "font_scale_factor": 1.0,
        "color": [1.0, 1.0, 1.0],
        "shadow": true,
        "hover_text_color": [0.4, 1.0, 0.4],
        "button_mappings": [
            { "from_button_id": "button.menu_select", "to_button_id": "veinminer_toggle_btn" }
        ]
    },

    "settings_button": {
        "type": "button",
        "size": [32, 22],
        "button_click_commands": ["/scriptevent veinminer:settings"],
        "default_control_id": "veinminer_settings_btn",
        "text": "⚙",
        "font_scale_factor": 1.2,
        "color": [1.0, 1.0, 1.0],
        "shadow": true,
        "hover_text_color": [1.0, 0.85, 0.2],
        "button_mappings": [
            { "from_button_id": "button.menu_select", "to_button_id": "veinminer_settings_btn" }
        ]
    },

    "vm_panel": {
        "type": "panel",
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "offset": [0, 0],
        "controls": [
            { "toggle_btn@veinminer_ui.toggle_button": {} },
            { "settings_btn@veinminer_ui.settings_button": {} }
        ]
    },

    "root_panel": {
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_front",
                "value": [
                    { "vm_panel@veinminer_ui.vm_panel": {} }
                ]
            }
        ]
    }
}